{
  "frontend": {
    "component_pattern": {
      "style": "CSS Modules + WDS Tokens",
      "structure": "Folder-based (Component/Component.tsx, Component.module.css)",
      "utils": "clsx for conditional classes",
      "layout": "Tailwind for layout only (flex, grid, gap)",
      "rules": [
        "Use CSS Modules with WDS token variables",
        "Wrap Radix UI primitives for complex interaction",
        "Export from index.ts"
      ]
    },
    "state_management": {
      "server": "React Query (TanStack Query)",
      "client": "Zustand (Persist middleware for settings)"
    },
    "form_pattern": {
      "library": "react-hook-form",
      "validation": "zod schema",
      "rules": "Must use zodResolver"
    },
    "wds_tokens": {
      "colors": [
        "--color-orange-500",
        "--color-grey-50",
        "--color-financial-*",
        "--color-brix-*"
      ],
      "typography": [
        "w1 (Headline)",
        "w4 (Body)",
        "financial-* (Tabular Nums)"
      ],
      "motion": "Standard easing, 150ms~400ms duration"
    }
  },
  "backend": {
    "active": {
      "architecture": "Go API -> PostgreSQL -> Worker",
      "db_access": "pgx + sqlc",
      "finance_rules": "Append-only ledger, idempotency keys, transaction boundaries",
      "state_rules": "Use canonical enums only"
    },
    "legacy": {
      "status": "migration_only",
      "notes": [
        "Spring Boot, Django, Oracle, and MyBatis are not default recommendations",
        "Use legacy skill only when explicitly migrating or comparing"
      ]
    }
  },
  "general": {
    "architecture": "React - Go - PostgreSQL",
    "commit_message": "Type: Subject \\n\\n Body"
  }
}
